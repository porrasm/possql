{
  "name": "piquel",
  "version": "0.1.1",
  "description": "Type-safe PostgreSQL database library with schema generation",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/porrasm/piquel.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests examples",
    "test": "vitest run --config tests/vitest.config.ts",
    "test:watch": "vitest --config tests/vitest.config.ts",
    "test:unit": "vitest run --config tests/vitest.config.ts tests/unit",
    "test:integration": "vitest run --config tests/vitest.config.ts tests/integration",
    "test:coverage": "vitest run --config tests/vitest.config.ts --coverage",
    "db:up": "docker compose -f tests/docker/docker-compose.yml up -d --wait",
    "db:down": "docker compose -f tests/docker/docker-compose.yml down -v",
    "typecheck:tests": "tsc --noEmit -p tests/tsconfig.json",
    "typecheck:examples": "tsc --noEmit -p examples/tsconfig.json",
    "example": "tsx examples/main.ts",
    "example:schema": "RUN_SCHEMA_GEN=true tsx examples/main.ts",
    "prettier:format": "prettier --write src tests examples",
    "prettier:check": "prettier --check src tests examples"
  },
  "dependencies": {
    "sql-template-strings": "^2.2.2",
    "zod": "^4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20",
    "@types/pg": "^8",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
    "pg": "^8",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  }
}
